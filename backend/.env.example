PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart_leads?retryWrites=true&w=majority
# Fixes querySrv ECONNREFUSED on some networks (optional for local mongodb://)
DNS_SERVERS=8.8.8.8,1.1.1.1
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173,https://smart-leads-dashboard-henna.vercel.app
NODE_ENV=development
